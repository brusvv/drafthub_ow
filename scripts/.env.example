# Локальные переменные окружения — НЕ коммитить в git
# Скопируй в .env и заполни реальными значениями из Supabase → Settings → API

SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=

# Опционально — нужен только для Google-логина и Sheets-экспорта
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=
