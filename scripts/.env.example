# Скопируй этот файл в .env и заполни значения.
# .env уже в .gitignore проекта — не попадёт в git.

# Supabase → Settings → API → Project URL
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Supabase → Settings → API → service_role key (СЕКРЕТНЫЙ, не anon key!)
# Нужен чтобы обойти RLS при разовом импорте — никогда не используй его
# во фронтенде и не коммить в git.
SUPABASE_SERVICE_ROLE_KEY=

# UUID команды (teams.id), в которую импортируются данные.
# Можно скопировать из Supabase Table Editor → teams.
TEAM_ID=

# Google Таблица: часть URL между /d/ и /edit
# https://docs.google.com/spreadsheets/d/ВОТ_ЭТО/edit
SHEET_ID=

# Путь к JSON-ключу сервисного аккаунта Google Cloud
# (Google Cloud Console → IAM → Service Accounts → Keys → Add Key → JSON).
# Таблицу нужно открыть на чтение для email из поля "client_email" этого ключа
# (Файл → Настройки доступа → добавить как Читатель).
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./service-account.json
